# Copy this file to keystore.properties or put the same values in ~/.gradle/gradle.properties.
# Environment variables with the same names also work.

RELEASE_STORE_FILE=keystore/spotifyhub-release.jks
RELEASE_STORE_PASSWORD=change_me
RELEASE_KEY_ALIAS=spotifyhub-release
# PKCS12 keystores use the same password for the store and key.
RELEASE_KEY_PASSWORD=change_me
